{
  "model": {
    "model_class": "Base_Ensemble_Model",
    "args": {
      "d_model": 40,
      "num_classes": 2,
      "fc_inner": 64,
      "dropout": 0.1,
      "cls_type": "linear",
      "clip_grad": false,
      "bias_infusion": {
        "method": "ReconBoost",
        "alpha": 0.8,
        "ensemble_stages": 4,
        "epoch_stages": 4,
        "use_ga": true,
        "weight1": 5.0,
        "weight2": 1.0,
        "use": true,
        "starting_epoch": 0,
        "ending_epoch": 1500
      },
      "multi_loss": {
        "multi_supervised_w": {
          "combined": 1,
          "c": 1,
          "g": 1
        }
      }
    },
    "load_ongoing": false,
    "ceu": {
      "val": "./artifacts/ceus/mustard/mustard_ceu_val.pkl",
      "test": "./artifacts/ceus/mustard/mustard_ceu_test.pkl"
    },
    "save_dir": "ReconBoost_{}.pth.tar",
    "encoders": [
      {
        "model": "FactorCL_Uni",
        "args": {
          "n_features": 371,
          "hidden_size": 40,
          "modality": "c",
          "num_classes": 2,
          "freeze_encoder": false
        },
        "pretrainedEncoder": {
          "use": false,
          "dir": "unimodal_video_fold{}_vldaccuracy_lr0.0005_wd0.00001.pth.tar"
        }
      },
      {
        "model": "FactorCL_Uni",
        "args": {
          "n_features": 300,
          "hidden_size": 40,
          "modality": "g",
          "num_classes": 2,
          "freeze_encoder": false
        },
        "pretrainedEncoder": {
          "use": false,
          "dir": "unimodal_text_fold{}_vldaccuracy_lr0.0005_wd0.0001.pth.tar"
        }
      }
    ]
  }
}

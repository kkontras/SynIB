{
  "model": {
    "model_class": "Base_Model",
    "args": {
      "d_model": 40,
      "num_classes": 2,
      "fc_inner": 64,
      "dropout": 0.1,
      "cls_type": "linear",
      "clip_grad": false,
      "bias_infusion": {
        "method": "OGM-Mine_Reg",
        "alpha": 1.0,
        "starting_epoch": 0,
        "ending_epoch": 1500,
        "use": true,
        "plot": false
      },
      "multi_loss": { "multi_supervised_w": { "combined": 1, "c": 1, "g": 1 } }
    },
    "load_ongoing": false,
    "save_dir": "MLB_{}.pth.tar",
    "ceu": {
      "val": "./artifacts/ceus/mosi/mosi_ceu_val.pkl",
      "test": "./artifacts/ceus/mosi/mosi_ceu_test.pkl"
    },
    "encoders": [
      {
        "model": "FactorCL_Uni",
        "args": { "n_features": 20, "hidden_size": 40, "modality": "c", "num_classes": 2, "freeze_encoder": false },
        "pretrainedEncoder": { "use": false, "dir": "unimodal_video_fold{}_vldaccuracy_lr0.0005_wd0.00001.pth.tar" }
      },
      {
        "model": "FactorCL_Uni",
        "args": { "n_features": 300, "hidden_size": 40, "modality": "g", "num_classes": 2, "freeze_encoder": false },
        "pretrainedEncoder": { "use": false, "dir": "unimodal_text_fold{}_vldaccuracy_lr0.0005_wd0.0001.pth.tar" }
      }
    ]
  }
}

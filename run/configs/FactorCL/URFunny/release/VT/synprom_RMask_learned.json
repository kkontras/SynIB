          "n_features": 371,
          "hidden_size": 40,
          "modality": "c",
          "num_classes": 2,
          "freeze_encoder": false
        },
        "pretrainedEncoder": {
          "use": true,
          "dir": "unimodal_video_fold{}_vldaccuracy_lr0.001_wd0.0001.pth.tar"
        }
      },
      {
        "model": "FactorCL_Uni",
        "args": {
          "n_features": 300,
          "hidden_size": 40,
          "modality": "g",
          "num_classes": 2,
          "freeze_encoder": false
        },
        "pretrainedEncoder": {
          "use": true,
          "dir": "unimodal_text_fold{}_vldaccuracy_lr0.001_wd0.001.pth.tar"
        }
      },
      {
        "name": "enc_2_fusion_trunk",
        "model": "FusionTrunkLinear",
        "args": {
          "d_model": 40,
          "fc_inner": 64,
          "dropout": 0.1,
          "freeze_encoder": false
        },
        "pretrainedEncoder": {
          "use": false,

          "combined": 1,
          "c": 1,
          "g": 1,
          "mask0": 1,
          "mask1": 1,
          "mask01": 1,
          "randmask0": 0,
          "randmask1": 0,
          "randmask01": 0
        }
      }
    },
    "load_ongoing": false,
    "ceu": {

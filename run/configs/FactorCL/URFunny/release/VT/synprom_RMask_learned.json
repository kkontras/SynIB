{
  "model": {
    "model_class": "FusionIBModel_Mask",
    "args": {
      "d_model": 40,
      "num_classes": 2,
      "fc_inner": 64,
      "dropout": 0.1,
      "cls_type": "mlp",
      "norm_decision": false,
      "bias_infusion": {},

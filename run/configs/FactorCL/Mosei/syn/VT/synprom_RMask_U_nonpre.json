{
  "model": {
    "model_class": "FusionIBModel_Mask_U",
    "args": {
      "d_model": 40, "num_classes": 2, "fc_inner": 64, "in_dim": 64, "hidden_dim": 64,
      "dropout": 0.1, "cls_type": "mlp", "norm_decision": false,
      "synergy_type": "unimodal_anchor",
      "bias_infusion": { "l": 0.1 },
      "multi_loss": { "multi_supervised_w": { "combined": 1 } }
    },
    "load_ongoing": false,
    "save_dir": "SynIB_RMask_U_nonpre_fold{}.pth.tar",
    "ceu": {
      "val": "./artifacts/ceus/mosei/mosei_ceu_val.pkl",
      "test": "./artifacts/ceus/mosei/mosei_ceu_test.pkl"
    },
    "encoders": [
      {
        "model": "FactorCL_Uni",
        "args": { "n_features": 35, "hidden_size": 40, "modality": "c", "num_classes": 2, "freeze_encoder": false },
        "pretrainedEncoder": { "use": false, "dir": "unimodal_video_fold{}.pth.tar" }
      },
      {
        "model": "FactorCL_Uni",
        "args": { "n_features": 300, "hidden_size": 40, "modality": "g", "num_classes": 2, "freeze_encoder": false },
        "pretrainedEncoder": { "use": false, "dir": "unimodal_text_fold{}.pth.tar" }
      }
    ]
  }
}

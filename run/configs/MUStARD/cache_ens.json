          "bias_infusion": {
            "method": "false",
            "use": false,
            "plot": false
          },
          "lora_config": {
            "use_lora": true,
            "lora_r": 8,
            "lora_alpha": 16,
            "lora_dropout": 0.05,
            "lora_target_modules": ["q_proj", "v_proj"],
            "lora_bias": "none",
            "lora_lr": 0.0002
          },
          "multi_loss": {
            "multi_supervised_w": {
              "combined": 0,
              "c": 0,
              "g": 0
            }
          }
        },
        "load_ongoing": false,
        "save_dir": "MUStARD_Cache_Video_LoRa_{}.pth.tar",
        "encoders": [
          {
            "model": "LinearHead_Qwen",
            "args": {
              "d_model": 2048,
              "num_classes": 2
            },
            "pretrainedEncoder": {
              "use": true,
              "dir": "MUStARD_Cache_Video_LoRa_{}.pth.tar"
            }
          }
        ],
        "pretrainedEncoder": {
          "use": true,
          "dir": "MUStARD_Cache_Video_LoRa_{}.pth.tar"
        }
      },
      {
        "model_name": "Qwen/Qwen3-VL-2B-Instruct",
        "model": "QwenVL_Cached_Text",
        "args": {
          "d_model": 512,
          "num_classes": 2,
          "fc_inner": 64,
          "dropout": 0.1,
          "cls_finetune": false,
          "cls_type": "linear",
          "clip_grad": true,
          "clip_value": 1.0,
          "bias_infusion": {
            "method": "false",
            "use": false,

{
  "dataset": {
    "data_split": {
      "fold": 0
    }
  },
  "model": {
    "model_class": "QwenVL_Cached_SynIBU",
    "load_ongoing": false,
    "save_dir": "MUStARD_Cache_SynIBU_LoRa_{}.pth.tar",
    "args": {
      "d_model": 512,
      "num_classes": 2,
      "fc_inner": 64,
      "dropout": 0.1,
      "cls_finetune": false,
      "cls_type": "linear",
      "clip_grad": true,
      "clip_value": 1.0,
      "perturb": {
        "reestimate_features": false,
        "p": 0.5,
        "num_samples": 1,
        "type": "rand"
      },
      "synergy_type": "unimodal_anchor",
      "bias_infusion": {
        "method": "false",
        "use": true,
        "l": 0.1,
        "starting_epoch": 0,
        "ending_epoch": 500,
        "plot": false
      },
      "lora_config": {
        "use_lora": true,
        "lora_r": 8,
        "lora_alpha": 16,
        "lora_dropout": 0.05,
        "lora_target_modules": [
          "q_proj",
          "v_proj"
        ],
        "lora_bias": "none",
        "lora_lr": 0.0002
      },
      "multi_loss": {
        "multi_supervised_w": {
          "combined": 0,
          "c": 0,
          "g": 0
        }
      }
    },
    "encoders": [
      {
        "model": "LinearHead_Qwen",
        "args": {
          "d_model": 2048,
          "num_classes": 2
        },
        "pretrainedEncoder": {
          "use": false,
          "dir": "{}"
        }
      }
    ]
  }
}
{
  "exp_name": "MUStARD Cache Experiment",
  "agent": "Agent",
  "training_params": {
    "cuda": true,
    "gpu_device": [0],
    "seed": 109,
    "batch_size": 32,
    "test_batch_size": 32,
    "data_loader_workers": 8,
    "pin_memory": false,

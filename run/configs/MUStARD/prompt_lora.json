{
  "dataset": {
    "data_split": {
      "fold": 0
    }
  },
  "model": {
    "model_class": "QwenVL_MUStARD_Prompt",
    "load_ongoing": false,
    "save_dir": "MUStARD_combined_lora_{}.pth.tar",
    "args": {
      "multi_loss": {
        "multi_supervised_w": {
          "combined": 0,
          "c": 0,
          "g": 0
        }
      }
    },
    "encoders": [
      {
        "model": "LinearHead_Qwen",
        "args": {
          "num_classes": 2,
          "d_model": 2048
        },
        "pretrainedEncoder": {
          "use": false,
          "dir": ""
        }
      }
    ]
  }
}
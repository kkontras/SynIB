{
  "dataset": {
    "data_split": {
      "fold": 0
    }
  },
  "model": {
    "model_class": "QwenVL_Cached_FullFT",
    "load_ongoing": false,
    "save_dir": "MUStARD_Cache_FullFT_{}.pth.tar",
    "args": {
      "d_model": 512,
      "num_classes": 2,
      "fc_inner": 64,
      "dropout": 0.1,
      "cls_finetune": false,
      "cls_type": "linear",
      "clip_grad": true,
      "clip_value": 1.0,
      "finetune_layers": "all",
      "bias_infusion": {
        "method": "false",
        "use": false,
        "plot": false
      },
      "lora_config": {
        "use_lora": false
      },
      "multi_loss": {
        "multi_supervised_w": {
          "combined": 0,
          "c": 0,
          "g": 0
        }
      }
    },
    "encoders": [
      {
        "model": "LinearHead_Qwen",
        "args": {
          "d_model": 2048,
          "num_classes": 2
        },
        "pretrainedEncoder": {
          "use": false,
          "dir": ""
        }
      }
    ]
  }
}

{
  "exp_name": "TQA Tier1 Train",
  "agent": "Agent",
  "training_params": {
    "cuda": true,
    "gpu_device": [
      0
    ],
    "seed": 109,
    "batch_size": 2,
    "test_batch_size": 2,
    "data_loader_workers": 1,
    "pin_memory": false,
    "async_loading": false,
    "validation": true,
    "rec_test": true,
    "test_on_bottoms": false,
    "use_test_set": true,
    "verbose": true,
    "adversarial_training": {
      "use": false,
      "adv_epsilon": 0.01
    },
    "tdqm_disable": true,
    "wandb_disable": false,
    "res": true,
    "gradient_accumulation_steps": 1
  },
  "scheduler": {
    "type": "cosanneal",
    "max_lr": 0.03,
    "warm_up_steps": 780

    "validate_every": 185,
    "save_every_valstep": 50,
    "validate_after": 0,
    "n_steps_stop": 100,
    "n_steps_stop_after": 0,
    "validate_with": "accuracy"
  },
  "dataset": {
    "dataloader_class": "TQA_MemmapDataloader",
    "data_roots": "/dodrio/scratch/projects/2026_029/kkontras/data/TQA",
    "cache_root": "/dodrio/scratch/projects/2026_029/kkontras/data/TQA/cache_qwen3_vl_2b"
  },
  "model": {
    "save_base_dir": "/dodrio/scratch/projects/2026_029/kkontras/checkpoints/synergy/TQA"
  }
